# omo-pulse environment configuration
# Copy this file to .env and adjust values as needed

# UI Development Server Port
# Port for Vite dev server in development mode
EZ_DASH_UI_PORT=4300

# API Server Port
# Port for the Bun backend API server
# Used in both development and production modes
EZ_DASH_API_PORT=4301

# CI Environment Indicator
# Set to "true" in CI/CD environments to prevent Playwright from reusing existing servers
# In local development, leave unset (defaults to false)
CI=

