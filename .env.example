# omo-pulse environment configuration
# Copy this file to .env and adjust values as needed

# UI / Production Server Port
# Port for Vite dev server (development) or the combined server (production)
OMO_PULSE_PORT=4300

# API Server Port (development only)
# Port for the Bun backend API server in dev mode
OMO_PULSE_API_PORT=4301

# CI Environment Indicator
# Set to "true" in CI/CD environments to prevent Playwright from reusing existing servers
# In local development, leave unset (defaults to false)
CI=
